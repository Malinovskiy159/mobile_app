<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Сплошной цвет фона -->
    <solid android:color="#F5F5F5" />

    <!-- Скругленные углы -->
    <corners android:radius="8dp" />

    <!-- Обводка (опционально) -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" />

    <!-- Внутренние отступы -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />
</shape>