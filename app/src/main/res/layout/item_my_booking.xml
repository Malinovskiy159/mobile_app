<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Верхняя часть с фото и основной информацией -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Фото вещи -->
            <ImageView
                android:id="@+id/imageItem"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_image"
                android:background="#F0F0F0"
                android:layout_marginEnd="12dp" />

            <!-- Информация о вещи -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Название вещи"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="Кухонный комбайн Braun" />

                <TextView
                    android:id="@+id/textCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Категория"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    tools:text="Техника" />

                <TextView
                    android:id="@+id/textOwnerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Владелец"
                    android:textColor="@color/purple_500"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Владелец: Иван Петров" />

            </LinearLayout>

        </LinearLayout>

        <!-- Статус и дата -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Статус"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Ожидает подтверждения" />

            <TextView
                android:id="@+id/textBookingDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Дата"
                android:textColor="#999999"
                android:textSize="12sp"
                tools:text="Забронировано: 2 дня назад" />

        </LinearLayout>

        <!-- Информация о встрече -->
        <TextView
            android:id="@+id/textMeetingInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Информация о встрече"
            android:textColor="#666666"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="Встреча: завтра в 15:00"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/textMeetingPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Место встречи"
            android:textColor="#666666"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="Место: м. Охотный ряд"
            tools:visibility="visible" />

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E0E0E0" />

        <!-- Кнопки действий -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPrimary"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Основное действие"
                android:textSize="14sp"
                app:cornerRadius="20dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:visibility="gone"
                tools:text="Связаться"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSecondary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Вторичное действие"
                android:textSize="14sp"
                app:cornerRadius="20dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:visibility="gone"
                tools:text="Отменить"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>