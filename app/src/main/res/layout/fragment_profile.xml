<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- БЛОК 1: Фото и имя -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Профиль"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:id="@+id/profileImageView"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/profile_placeholder"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:id="@+id/addPhotoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Добавить фото"
                    android:textColor="@color/purple_500"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <EditText
                android:id="@+id/userNameEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Имя пользователя"
                android:textSize="16sp"
                android:backgroundTint="@color/purple_500" />

        </LinearLayout>

        <!-- БЛОК 2: Геолокация -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Геолокация"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:drawable/editbox_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/locationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Геолокация не определена"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/specifyLocationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Указать геолокацию"
                android:textColor="@color/purple_500"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp" />

            <!-- Ручной ввод (скрыт по умолчанию) -->
            <LinearLayout
                android:id="@+id/manualLocationLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/manualLocationEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Введите адрес"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/manualLocationButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сохранить"
                    android:backgroundTint="@color/purple_500" />

            </LinearLayout>

            <Button
                android:id="@+id/autoDetectButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Определить автоматически"
                android:backgroundTint="@color/purple_500" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>